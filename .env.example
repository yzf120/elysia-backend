# Elysia Backend 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置

# ========================
# 服务器配置
# ========================

# 服务器端口 (默认: 8080)
PORT=8080

# Gin运行模式 (debug/release/test)
GIN_MODE=debug

# ========================
# 数据库配置
# ========================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口 (MySQL默认: 3306)
DB_PORT=3306

# 数据库用户名
DB_USER=root

# 数据库密码
DB_PASSWORD=password

# 数据库名称
DB_NAME=elysia

# ========================
# 应用配置
# ========================

# 应用名称
APP_NAME=elysia-backend

# 应用版本
APP_VERSION=1.0.0

# ========================
# 日志配置
# ========================

# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

# 日志输出格式 (json/text)
LOG_FORMAT=text

# ========================
# 安全配置
# ========================

# JWT密钥 (用于身份验证)
JWT_SECRET=your-jwt-secret-key-here

# API密钥 (用于外部API调用)
API_KEY=your-api-key-here

# ========================
# 开发配置
# ========================

# 是否启用Swagger文档 (true/false)
ENABLE_SWAGGER=true

# 是否启用CORS (true/false)
ENABLE_CORS=true

# ========================
# Docker配置
# ========================

# Docker Compose环境下的数据库配置
# DB_HOST=mysql
# DB_USER=elysia
# DB_PASSWORD=elysia123

# ========================
# Redis配置
# ========================

# Redis主机地址
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis密码（如果没有密码则留空）
REDIS_PASSWORD=

# Redis数据库编号（0-15）
REDIS_DB=0

# ========================
# 腾讯云短信配置
# ========================

# 腾讯云短信SecretId
TENCENT_SMS_SECRET_ID=your-secret-id

# 腾讯云短信SecretKey
TENCENT_SMS_SECRET_KEY=your-secret-key

# 腾讯云短信应用ID
TENCENT_SMS_SDK_APP_ID=your-sdk-app-id

# 腾讯云短信签名
TENCENT_SMS_SIGN_NAME=your-sign-name

# 腾讯云短信模板ID
TENCENT_SMS_TEMPLATE_ID=your-template-id

# 腾讯云短信地域（默认：ap-guangzhou）
TENCENT_SMS_REGION=ap-guangzhou
