# =============================================
# 5. 完整流程测试（创建 → 查询 → 更新 → 查询验证 → 删除）
# =============================================

# 5.1 步骤1: 创建新题目
curl --request POST \
  --url http://localhost:8001/api/teacher/problem/create \
  --header 'Content-Type: application/json' \
  --header 'Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk' \
  --data '{
  "title": "流程测试题目",
  "title_slug": "flow-test-problem",
  "difficulty": "简单",
  "tags": "测试",
  "description": "这是一道用于完整流程测试的题目",
  "hint": "这是提示",
  "constraints": "1 <= n <= 100",
  "test_cases": "[{\"input\":\"1\",\"expected_output\":\"1\",\"is_sample\":1,\"explanation\":\"测试用例\"}]"
}'

# 5.2 步骤2: 查询刚创建的题目（替换 id 为步骤1返回的 id）
curl --request GET \
  --url 'http://localhost:8001/api/problem/get?id=4' \
  --header 'Content-Type: application/json' \
  --header 'Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk'

# 5.3 步骤3: 更新题目信息
curl --request POST \
  --url http://localhost:8001/api/teacher/problem/update \
  --header 'Content-Type: application/json' \
