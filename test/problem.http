# =============================================
# 题目管理 API - curl 测试用例
# 使用方式：复制单条或多条 curl 命令，粘贴到 Apifox「导入 cURL」中批量导入
# 注意：请将 eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk / eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJTVFUwMDEiLCJpc3MiOiJlbHlzaWEtYmFja2VuZCIsImV4cCI6MTc3MjUwODQ1NiwiaWF0IjoxNzcyNDIyMDU2fQ.XBmx2eD6HQ18u8Qmwe9pbjZL7mkCaoHTY9Qh6CS10qY 替换为实际登录后获取的 JWT token
# =============================================


# =============================================
# 1. 创建题目（仅教师）POST /api/teacher/problem/create
# =============================================

# 1.1 创建题目 - 两数之和
curl --request POST \
  --url http://localhost:8001/api/teacher/problem/create \
  --header 'Content-Type: application/json' \
  --header 'Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk' \
  --data '{
  "title": "两数之和",
  "title_slug": "two-sum",
  "difficulty": "简单",
  "tags": "哈希表,数组",
  "description": "给定一个整数数组 nums 和一个整数目标值 target，请你在该数组中找出和为目标值 target 的那两个整数，并返回它们的数组下标。\n你可以假设每种输入只会对应一个答案，并且你不能使用两次相同的元素。\n你可以按任意顺序返回答案。",
  "explanation": "因为 nums[0] + nums[1] == 9，返回 [0, 1]。",
  "hint": "可以尝试使用哈希表来降低时间复杂度",
  "constraints": "2 <= nums.length <= 10^4\n-10^9 <= nums[i] <= 10^9\n-10^9 <= target <= 10^9\n只会存在一个有效答案",
  "advanced_requirement": "进阶：你可以想出一个时间复杂度小于 O(n²) 的算法吗？",
  "test_cases": "[{\"input\":\"4\\n2 7 11 15\\n9\",\"expected_output\":\"0 1\",\"is_sample\":1,\"explanation\":\"nums[0] + nums[1] = 2 + 7 = 9\"},{\"input\":\"3\\n3 2 4\\n6\",\"expected_output\":\"1 2\",\"is_sample\":1,\"explanation\":\"nums[1] + nums[2] = 2 + 4 = 6\"},{\"input\":\"2\\n3 3\\n6\",\"expected_output\":\"0 1\",\"is_sample\":1,\"explanation\":\"nums[0] + nums[1] = 3 + 3 = 6\"}]"
}'

# 1.2 创建题目 - 反转链表
curl --request POST \
  --url http://localhost:8001/api/teacher/problem/create \
  --header 'Content-Type: application/json' \
  --header 'Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk' \
  --data '{
  "title": "反转链表",
  "title_slug": "reverse-linked-list",
  "difficulty": "简单",
  "tags": "链表,递归",
  "description": "给你单链表的头节点 head，请你反转链表，并返回反转后的链表。",
  "explanation": "输入：head = [1,2,3,4,5]，输出：[5,4,3,2,1]",
  "hint": "可以使用迭代或递归两种方式实现",
  "constraints": "链表中节点的数目范围是 [0, 5000]\n-5000 <= Node.val <= 5000",
  "advanced_requirement": "链表可以选用迭代或递归方式完成反转。你能否用两种方法解决这道题？",
  "test_cases": "[{\"input\":\"5\\n1 2 3 4 5\",\"expected_output\":\"5 4 3 2 1\",\"is_sample\":1,\"explanation\":\"反转整个链表\"},{\"input\":\"2\\n1 2\",\"expected_output\":\"2 1\",\"is_sample\":1,\"explanation\":\"反转两个节点的链表\"},{\"input\":\"1\\n0\",\"expected_output\":\"0\",\"is_sample\":1,\"explanation\":\"单节点链表反转后不变\"}]"
}'

# 1.3 创建题目 - 最长公共子序列
curl --request POST \
  --url http://localhost:8001/api/teacher/problem/create \
  --header 'Content-Type: application/json' \
  --header 'Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZWFfVENIMDAxIiwiaXNzIjoiZWx5c2lhLWJhY2tlbmQiLCJleHAiOjE3NzI1MDk4OTMsImlhdCI6MTc3MjQyMzQ5M30.0few6lF3D5o27EqOq818jPiheeCVghzBxmV5v0RaEIk' \
  --data '{
  "title": "最长公共子序列",
  "title_slug": "longest-common-subsequence",
  "difficulty": "中等",
  "tags": "动态规划,字符串",
  "description": "给定两个字符串 text1 和 text2，返回这两个字符串的最长公共子序列的长度。如果不存在公共子序列，返回 0。",
  "explanation": "输入：text1 = \"abcde\", text2 = \"ace\"，输出：3，解释：最长公共子序列是 \"ace\"，它的长度为 3。",
  "hint": "尝试使用动态规划，定义 dp[i][j] 为 text1[0..i-1] 和 text2[0..j-1] 的最长公共子序列长度",
  "constraints": "1 <= text1.length, text2.length <= 1000\ntext1 和 text2 仅由小写英文字符组成",
  "advanced_requirement": "",
  "test_cases": "[{\"input\":\"abcde\\nace\",\"expected_output\":\"3\",\"is_sample\":1,\"explanation\":\"最长公共子序列是 ace\"},{\"input\":\"abc\\nabc\",\"expected_output\":\"3\",\"is_sample\":1,\"explanation\":\"两字符串相同\"},{\"input\":\"abc\\ndef\",\"expected_output\":\"0\",\"is_sample\":1,\"explanation\":\"无公共子序列\"}]"
}'

# 1.4 创建题目 - 缺少必填字段（测试错误处理）
curl --request POST \
